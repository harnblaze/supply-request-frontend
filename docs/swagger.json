    "tags": [],
    "servers": [],
    "components": {
      "schemas": {
        "CreateApplicationDto": {
          "type": "object",
          "properties": {
            "applicationNumber": {
              "type": "string",
              "maxLength": 128,
              "example": "Z-2026-000123"
            },
            "comment": {
              "type": "string",
              "maxLength": 10000
            }
          }
        },
        "UpdateApplicationDto": {
          "type": "object",
          "properties": {
            "applicationNumber": {
              "type": "string",
              "maxLength": 128,
              "example": "Z-2026-000123"
            },
            "status": {
              "type": "string",
              "enum": ["DRAFT", "SENT_TO_SUPPLY"]
            },
            "comment": {
              "type": "string",
              "maxLength": 10000
            }
          }
        },
        "CreateInvoiceDto": {
          "type": "object",
          "properties": {
            "applicationId": {
              "type": "string",
              "format": "uuid"
            },
            "supplier": {
              "type": "string",
              "maxLength": 256,
              "example": "ООО Ромашка"
            },
            "amount": {
              "type": "string",
              "example": "12345.67",
              "description": "Decimal string"
            }
          },
          "required": ["applicationId", "supplier", "amount"]
        },
        "UpdateInvoiceDto": {
          "type": "object",
          "properties": {
            "supplier": {
              "type": "string",
              "maxLength": 256,
              "example": "ООО Ромашка"
            },
            "amount": {
              "type": "string",
              "example": "12345.67",
              "description": "Decimal string"
            }
          }
        },
        "CreateMaterialDto": {
          "type": "object",
          "properties": {
            "applicationId": {
              "type": "string",
              "format": "uuid"
            },
            "name": {
              "type": "string",
              "maxLength": 512,
              "example": "Кабель ВВГнг 3x2.5"
            },
            "orderedQuantity": {
              "type": "number",
              "minimum": 1,
              "example": 10
            },
            "deliveredQuantity": {
              "type": "number",
              "minimum": 0,
              "example": 0
            }
          },
          "required": ["applicationId", "name", "orderedQuantity"]
        },
        "UpdateMaterialDto": {
          "type": "object",
          "properties": {
            "deliveredQuantity": {
              "type": "number",
              "minimum": 0,
              "example": 3
            }
          }
        }
      }
    }
